# Copy to .env and adjust. The .env file is gitignored — never commit real values.

# docker-compose database
POSTGRES_DB=fundflow
POSTGRES_USER=fundflow
POSTGRES_PASSWORD=fundflow

# Spring Boot datasource (defaults already match docker-compose for local dev)
DB_URL=jdbc:postgresql://localhost:5432/fundflow
DB_USERNAME=fundflow
DB_PASSWORD=fundflow

# Schema management: 'create' for dev, 'validate' for prod
DDL_AUTO=create
# Seed data: 'always' for dev, 'never' for prod
SQL_INIT_MODE=always
